# Neos.Neos.Shortcut is given a representation for editing purposes
#
prototype(Neos.Neos:Shortcut) < prototype(Neos.Fusion:Component) {
  targetMode = ${q(node).property('targetMode')}
  firstChildNode = ${q(node).children('[instanceof Neos.Neos:Document]').get(0)}
  target = ${q(node).property('target')}
  targetConverted = ${Neos.Link.hasSupportedScheme(this.target) ? Neos.Link.convertUriToObject(this.target, node) : null}
  targetSchema = ${Neos.Link.getScheme(this.target)}

  i18n = ${q(Neos.BackendUser.get()).property('preferences.interfaceLanguage')}

  renderer = Neos.Fusion:Match {
    @subject = ${props.targetMode}
  }

  // targetMode == 'selectedTarget'
  renderer.selectedTarget = Neos.Fusion:Join {
    generalMessage = Neos.Fusion:Renderer {
      fallback = 'This is a shortcut to a specific target:'
      renderer = ${I18n.id('shortcut.toSpecificTarget').package('Neos.Neos').source('Main').value(this.fallback).locale(props.i18n).translate()}
    }
    ifTarget = Neos.Fusion:Case {
      default {
        @position = 'end'
        condition = true
        renderer = Neos.Fusion:Renderer {
          fallback = 'no target has been selected'
          renderer = ${I18n.id('shortcut.noTargetSelected').package('Neos.Neos').source('Main').value(this.fallback).locale(props.i18n).translate()}
        }
      }
    }
    @glue = "<br/>"
  }

  renderer.selectedTarget.ifTarget.condition {
    condition = ${props.target}
    renderer = Neos.Fusion:Match {
      @subject = ${props.targetSchema}

      node = Neos.Fusion:Renderer {
        targetUriTag = Neos.Neos:NodeLink {
          node = ${props.targetConverted}
        }
        fallback = afx`
          Click {this.targetUriTag} to continue to the page.
        `
        renderer = ${I18n.id('shortcut.clickToContinueToPage').package('Neos.Neos').source('Main').arguments([this.targetUriTag]).value(this.fallback).locale(props.i18n).translate()}
      }

      asset = Neos.Fusion:Renderer {
        targetUriTag = Neos.Fusion:Tag {
          tagName = 'a'
          attributes {
            href = Neos.Fusion:ResourceUri {
              resource = ${props.targetConverted.resource}
            }
            target = "_blank"
          }
          content = ${props.targetConverted.label}
        }
        fallback = afx`
          Click {this.targetUriTag} to see the file.
        `
        renderer = ${I18n.id('shortcut.clickToContinueToAsset').package('Neos.Neos').source('Main').arguments([this.targetUriTag]).value(this.fallback).locale(props.i18n).translate()}
      }

      @default = Neos.Fusion:Renderer {
        targetUriTag = Neos.Fusion:Tag {
          tagName = 'a'
          attributes {
            href = ${props.target}
            target = "_blank"
          }
          content = ${props.target}
        }
        fallback = afx`
          Click {this.targetUriTag} to open the link.
        `
        renderer = ${I18n.id('shortcut.clickToContinueToExternalUrl').package('Neos.Neos').source('Main').arguments([this.targetUriTag]).value(this.fallback).locale(props.i18n).translate()}
      }
    }
  }

  // targetMode == 'firstChildNode'
  renderer.firstChildNode = Neos.Fusion:Renderer {
    targetUriTag = Neos.Neos:NodeLink {
      node = ${props.firstChildNode}
    }
    fallback = afx`
      This is a shortcut to the first child page.<br/>
      Click {this.targetUriTag} to continue to the page.
    `
    renderer = ${I18n.id('shortcut.clickToContinueToFirstChildNode').package('Neos.Neos').source('Main').arguments([this.targetUriTag]).value(this.fallback).locale(props.i18n).translate()}
  }

  // targetMode == 'parentNode'
  renderer.parentNode = Neos.Fusion:Renderer {
    targetUriTag = Neos.Neos:NodeLink {
      node = ${props.node.parent}
    }
    fallback = afx`
      This is a shortcut to the parent page.<br/>
      Click {this.targetUriTag} to continue to the page.
    `
    renderer = ${I18n.id('shortcut.clickToContinueToParentNode').package('Neos.Neos').source('Main').arguments([this.targetUriTag]).value(this.fallback).locale(props.i18n).translate()}
  }

  renderer.@process.contentWrap = afx`
    <div id="neos-shortcut">
      <p>
        {value}
      </p>
    </div>
  `

  @cache {
    mode = 'dynamic'
    entryIdentifier {
      node = ${node}
		}
    entryDiscriminator = ${q(Neos.BackendUser.get()).property('preferences.interfaceLanguage')}
    context {
        1 = 'node'
        2 = 'documentNode'
    }
    entryTags {
        1 = ${Neos.Caching.nodeTag(node)}
    }
  }

  @exceptionHandler = 'Neos\\Neos\\Fusion\\ExceptionHandlers\\NodeWrappingHandler'
}
